# Function to compare bridge centrality indices across T0, T1, and T2
compareBridge3 <- function(bridge_T0, bridge_T1, bridge_T2,
                           decreasing = TRUE,
                           legendName = "Time") {
  
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  
  # Mapping from current node names to "Code - Label" format
  node_label_map <- c(
    "Delusions" = "P1 - Delusions",
    "Conceptual disorganization" = "P2 - Conceptual disorganization",
    "Hallucinatory behavior" = "P3 - Hallucinatory behavior",
    "Excitement" = "P4 - Excitement",
    "Grandiosity" = "P5 - Grandiosity",
    "Suspiciousness" = "P6 - Suspiciousness",
    "Hostility" = "P7 - Hostility",
    
    "Blunted affect" = "N1 - Blunted affect",
    "Emotional withdrawal" = "N2 - Emotional withdrawal",
    "Poor rapport" = "N3 - Poor rapport",
    "Passive social withdrawal" = "N4 - Passive social withdrawal",
    "Difficulty in abstract thinking" = "N5 - Difficulty in abstract thinking",
    "Lack of spontaneity" = "N6 - Lack of spontaneity",
    "Stereotyped thinking" = "N7 - Stereotyped thinking",
    
    "Somatic concern" = "G1 - Somatic concern",
    "Anxiety" = "G2 - Anxiety",
    "Guilt feelings" = "G3 - Guilt feelings",
    "Tension" = "G4 - Tension",
    "Mannerisms" = "G5 - Mannerisms and posturing",
    "Depression" = "G6 - Depression",
    "Motor retardation" = "G7 - Motor retardation",
    "Uncooperativeness" = "G8 - Uncooperativeness",
    "Unusual thought content" = "G9 - Unusual thought content",
    "Disorientation" = "G10 - Disorientation",
    "Poor attention" = "G11 - Poor attention",
    "Lack of judgment and insight" = "G12 - Lack of judgment and insight",
    "Disturbance of volition" = "G13 - Disturbance of volition",
    "Poor impulse control" = "G14 - Poor impulse control",
    "Preoccupation" = "G15 - Preoccupation",
    "Active social avoidance" = "G16 - Active social avoidance"
  )
  
  extract_bridge <- function(bridge_obj, time_label) {
    s <- summary(bridge_obj)
    tibble(
      node = rownames(s),
      `Bridge Strength` = s$Bridge.Strength,
      `Bridge Expected Influence (1-step)` = s$Bridge.Expected.Influence..1.step.,
      Time = time_label
    )
  }
  
  df <- bind_rows(
    extract_bridge(bridge_T0, "T0"),
    extract_bridge(bridge_T1, "T1"),
    extract_bridge(bridge_T2, "T2")
  ) %>%
    pivot_longer(
      cols = c(`Bridge Strength`, `Bridge Expected Influence (1-step)`),
      names_to = "type",
      values_to = "value"
    ) %>%
    filter(!is.na(value), !is.na(node)) %>%
    mutate(
      # Replace only if a matching label is found; otherwise keep the original label
      node = ifelse(node %in% names(node_label_map), node_label_map[node], node)
    )
  
  # Node ordering is defined based on T0 Bridge Strength values
  ref_order <- df %>%
    filter(Time == "T0", type == "Bridge Strength") %>%
    arrange(if (decreasing) desc(value) else value) %>%
    pull(node)
  
  df <- df %>%
    mutate(
      # With coord_flip(), rev(ref_order) places the highest values at the top
      node = factor(node, levels = rev(ref_order)),
      Time = factor(Time, levels = c("T0", "T1", "T2"))
    )
  
  ggplot(df, aes(x = node, y = value, color = Time, group = Time)) +
    geom_line(linewidth = 1.2) +
    geom_point(size = 2.6) +
    coord_flip() +
    facet_grid(~type, scales = "free_x") +
    scale_color_manual(
      name = legendName,
      values = c("T0" = "#1B9E77", "T1" = "#D95F02", "T2" = "#7570B3")
    ) +
    labs(x = NULL, y = NULL) +
    theme_bw(base_size = 12) +
    theme(
      legend.position = "top",
      strip.background = element_rect(fill = "grey90"),
      panel.grid.minor = element_blank()
    )
}

compareBridge3(
  bridge_T0 = mybridge_T0,
  bridge_T1 = mybridge_T1,
  bridge_T2 = mybridge_T2
)

