# Full node names for legends and interactive display
nodeNames_panss <- c(
  PANSSP1 = "Delusions",
  PANSSP2 = "Conceptual disorganization",
  PANSSP3 = "Hallucinatory behavior",
  PANSSP4 = "Excitement",
  PANSSP5 = "Grandiosity",
  PANSSP6 = "Suspiciousness",
  PANSSP7 = "Hostility",
  
  PANSSN1 = "Blunted affect",
  PANSSN2 = "Emotional withdrawal",
  PANSSN3 = "Poor rapport",
  PANSSN4 = "Passive social withdrawal",
  PANSSN5 = "Difficulty in abstract thinking",
  PANSSN6 = "Lack of spontaneity",
  PANSSN7 = "Stereotyped thinking",
  
  PANSSG1  = "Somatic concern",
  PANSSG2  = "Anxiety",
  PANSSG3  = "Guilt feelings",
  PANSSG4  = "Tension",
  PANSSG5  = "Mannerisms",
  PANSSG6  = "Depression",
  PANSSG7  = "Motor retardation",
  PANSSG8  = "Uncooperativeness",
  PANSSG9  = "Unusual thought content",
  PANSSG10 = "Disorientation",
  PANSSG11 = "Poor attention",
  PANSSG12 = "Lack of judgment and insight",
  PANSSG13 = "Disturbance of volition",
  PANSSG14 = "Poor impulse control",
  PANSSG15 = "Preoccupation",
  PANSSG16 = "Active social avoidance"
)

# Predefined symptom domains used for plotting and bridge estimation
groups <- list("positive_symptoms" = c(1:7), "negative_cognitive" = c(8:14), "general_symptoms" = c(15:30))

# Plot the estimated baseline network
plot_panss_T0 <- qgraph(
  nwk_panss_T0$graph,
  layout = "spring",
  
  labels    = node_labels,
  nodeNames = nodeNames_panss,
  color     = colors,
  groups    = groups,
  
  legend = TRUE,
  legend.mode = "names",
  legend.cex  = 0.6,     
  
  GLratio = 3.2,         
  
  label.cex   = 0.9,
  label.color = "black",
  label.prop  = 1,
  
  border.width = 1,
  negDashed   = F,
  curveAll    = TRUE,
  curveDefault = 0.35,
  
  # Edge colors are explicitly defined here
  posCol = "blue",   
  negCol = "red",    
  
  font = 2
)

# Save the network graph
qgraph(plot_panss_T0, filetype='jpeg', dpi = 300)

# Nonparametric bootstrap to assess edge-weight accuracy
btnt_np <- bootnet(nwk_panss_T0,
                   type = "nonparametric",
                   statistics = "edge",
                   nBoots = 100,
                   verbose = FALSE,
                   nCores = 1)

plot(btnt_np,
     order = "sample")

plot(btnt_np, 
     plot = "difference",
     order = "sample")

## estimating network stability

# Case-dropping bootstrap for centrality stability estimation
b1 <- bootnet(nwk_panss_T0, boots = 1000, nCores = 4, statistics = "all", nBoots = 100, type = "case")

## obtaining centrality stability coefficients

corStability(b1)

plot(b1, statistics = c("strength", "betweenness", "closeness", "expectedInfluence"))

ggsave(filename = "stability_plot_1.jpeg", dpi = 300)

# Create centrality plots
c1 <- centralityPlot(plot_panss_T0, orderBy = "Strength")

# Simulation-based recoverability analysis
Sim1 <- netSimulator(
  input = nwk_panss_T0, 
  default = "EBICglasso",
  nCases = seq(200, 1000, 200),
  nReps = 100)

plot(Sim1)

