  PANSSN2 = "#4C72B0",  # emotional withdrawal
  PANSSN3 = "#4C72B0",  # poor rapport
  PANSSN4 = "#4C72B0",  # passive social withdrawal
  PANSSN5 = "#4C72B0",  # difficulty in abstract thinking
  PANSSN6 = "#4C72B0",  # lack of spontaneity
