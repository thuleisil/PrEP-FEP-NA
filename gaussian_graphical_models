  PANSSG3  = "#1B9E77", # guilt feelings
  PANSSG4  = "#1B9E77", # tension
  PANSSG5  = "#1B9E77", # mannerisms
  PANSSG6  = "#1B9E77", # depression
  PANSSG7  = "#1B9E77", # motor retardation
  PANSSG8  = "#1B9E77", # uncooperativeness
  PANSSG9  = "#1B9E77", # unusual thought content
  PANSSG10 = "#1B9E77", # disorientation
  PANSSG11 = "#1B9E77", # poor attention
  PANSSG12 = "#1B9E77", # lack of judgment
  PANSSG13 = "#1B9E77", # disturbance of volition
  PANSSG14 = "#1B9E77", # poor impulse control
  PANSSG15 = "#1B9E77", # preoccupation
  PANSSG16 = "#1B9E77"  # active social avoidance
)

# Abbreviated node labels for plotting
node_labels <- c(
  PANSSP1 = "P1", PANSSP2 = "P2", PANSSP3 = "P3",
  PANSSP4 = "P4", PANSSP5 = "P5", PANSSP6 = "P6", PANSSP7 = "P7",
  
